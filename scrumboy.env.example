# Example SCRUMBOY_ENCRYPTION_KEY assignment for Docker Compose, systemd, Kubernetes,
# or other external secret injection. The server does not auto-load this file.
# Generate one with: openssl rand -base64 32
# Or on Windows PowerShell: [Convert]::ToBase64String((1..32 | ForEach-Object { [byte](Get-Random -Maximum 256) }))
SCRUMBOY_ENCRYPTION_KEY=REPLACE_WITH_BASE64_32_BYTE_KEY

# Optional: enable Web Push / PWA background assignment notifications.
# Both keys are required together. These values must be injected by your process manager
# or Compose/Kubernetes environment; the server does not auto-load this file.
SCRUMBOY_VAPID_PUBLIC_KEY=REPLACE_WITH_VAPID_PUBLIC_KEY
SCRUMBOY_VAPID_PRIVATE_KEY=REPLACE_WITH_VAPID_PRIVATE_KEY

# Optional: contact hint for VAPID JWT "sub" (plain email or full mailto:/https: URL).
SCRUMBOY_VAPID_SUBSCRIBER=ops@example.com

# Optional: set to 1 to log push send/prune behavior on the server.
SCRUMBOY_DEBUG_PUSH=0

# Optional: enable Markdown preview in todo Notes.
# Accepted truthy values: 1, true, on, yes (case-insensitive).
SCRUMBOY_MARKDOWN_NOTES_ENABLED=0

# Optional: enable Mermaid diagram rendering inside fenced ```mermaid blocks
# in the todo Notes preview tab. This only works when
# SCRUMBOY_MARKDOWN_NOTES_ENABLED is also enabled.
SCRUMBOY_MERMAID_NOTES_ENABLED=0

# Optional: maximum raw Trello single-board JSON upload size for /api/import/trello/*
# Default is 33554432 (32 MiB).
MAX_TRELLO_IMPORT_BYTES=33554432

# Optional: enable self-service "forgot password" emails via SMTP. Host and From
# are required; Port defaults to 587 when omitted (if explicitly set, must be
# 1–65535). Username/Password are optional (some relays allow trusted-network
# submission without auth). Also requires SCRUMBOY_ENCRYPTION_KEY above (used to
# sign the reset token). These values must be injected by your process manager
# or Compose/Kubernetes environment; the server does not auto-load this file.
# See docs/smtp.md.
SCRUMBOY_SMTP_HOST=smtp.example.com
SCRUMBOY_SMTP_PORT=587
SCRUMBOY_SMTP_USERNAME=
SCRUMBOY_SMTP_PASSWORD=
SCRUMBOY_SMTP_FROM=Scrumboy <no-reply@example.com>

# Optional: SMTP TLS mode. "starttls" (default, port 587), "implicit" (port 465),
# or "none" (plaintext; local/dev only, e.g. MailHog/Mailpit).
SCRUMBOY_SMTP_TLS_MODE=starttls

# Optional: set to 1 to log SMTP send attempts (never logs credentials or message bodies).
SCRUMBOY_SMTP_DEBUG=0

# Required for self-service password-reset email (with SMTP above): fixed public
# origin, e.g. https://scrumboy.example.com. Missing or invalid values disable
# self-service email (generic API response only). When set, this is also the
# canonical OAuth discovery issuer. For OAuth, non-loopback issuers must be
# HTTPS (loopback http://localhost / 127.0.0.0/8 / ::1 is the local-dev
# exception). See docs/smtp.md and docs/oauth.md.
SCRUMBOY_PUBLIC_BASE_URL=https://scrumboy.example.com

# Optional: honor X-Forwarded-For for auth/OAuth rate-limit IP keys and (for
# OAuth issuer discovery) trusted X-Forwarded-Proto / X-Forwarded-Host /
# CF-Visitor. Default off (RemoteAddr only for IP keys). Enable only behind a
# reverse proxy that overwrites/strips client-supplied values for all of those
# headers — not only XFF. Accepts 1/true/on/yes. When SCRUMBOY_TRUST_PROXY=1,
# OAuth issuer discovery requires either SCRUMBOY_PUBLIC_BASE_URL or a
# proxy-provided X-Forwarded-Host together with a forwarded HTTPS indication.
# A proxy that sends only X-Forwarded-Proto (or multi-value forwarded
# scheme/host fields) receives 503 from OAuth discovery.
# SCRUMBOY_TRUST_PROXY=0
