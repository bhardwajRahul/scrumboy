{
  "name": "scrumboy-web",
  "version": "1.0.0",
  "private": true,
  "packageManager": "npm@11.6.1",
  "engines": {
    "node": "^20.19.0 || ^22.13.0 || >=24.0.0"
  },
  "scripts": {
    "postinstall": "node scripts/sync-vendor.mjs",
    "sync:vendor": "node scripts/sync-vendor.mjs",
    "verify:vendor": "node scripts/verify-vendor.mjs",
    "verify:i18n": "node scripts/verify-i18n-locales.mjs",
    "generate:landing": "node scripts/generate-landing.mjs",
    "verify:landing": "node scripts/generate-landing.mjs --check",
    "test:landing-layout": "playwright test --config=playwright.config.ts",
    "copy:i18n": "node scripts/copy-i18n-locales.mjs",
    "build": "node scripts/verify-vendor.mjs && npm run verify:i18n && npm run generate:landing && tsc && npm run copy:i18n",
    "test": "node scripts/verify-vendor.mjs && npm run verify:i18n && npm run verify:landing && vitest run",
    "lint:delete-confirms": "node scripts/check-delete-confirms.mjs"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "happy-dom": "^20.9.0",
    "jsdom": "^29.1.1",
    "typescript": "^5.0.0",
    "vite": "6.4.3",
    "vitest": "3.2.6"
  },
  "dependencies": {
    "dompurify": "3.4.11",
    "markdown-it": "14.2.0",
    "mermaid": "11.15.0",
    "uplot": "^1.6.32"
  }
}
